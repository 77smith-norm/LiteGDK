        "tests/helpers/"
      ],
      "docs": [
        "docs/architecture/",
        "docs/compatibility/",
        "docs/testing/",
        "docs/contributing/"
      ]
    },
    "compatibility_tiers": {
      "A": "Source-friendly and behaviorally aligned for intended educational use",
      "B": "Supported with small behavioral differences or limited edge-case coverage",
      "C": "Approximate/stubbed; compiles and documents limitations",
      "X": "Unsupported"
    }
  },
  "global_constraints": {
    "api_constraints": [
      "Primary include remains DarkGDK.h",
      "Public API uses db-prefixed free functions",
      "Asset handles are integer-based",
      "No exceptions cross the public API boundary",
      "Prefer deterministic defaults and explicit resettable runtime state"
    ],
    "testing_constraints": [
      "Headless-testable logic must live outside direct raylib draw calls",
      "Registries, command translation, and frame state must be unit tested",
      "Every bug fix adds a regression test",
      "Integration smoke tests must cover at least one textbook-style sample per implemented command family"
    ],
    "tooling_constraints": [
      "CMake presets supported",
      "VS Code tasks and launch configs provided",
      "Avoid unnecessary dependencies beyond raylib and Catch2"
    ]
  },
