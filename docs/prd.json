{
  "schema_version": "1.0",
  "artifact_type": "implementation_roadmap",
  "artifact_name": "prd.json",
  "project": {
    "name": "LiteGDK",
    "tagline": "DarkGDK-inspired educational compatibility SDK built on raylib",
    "status": "draft",
    "primary_language": "C++20",
    "backend": "raylib",
    "build_system": "CMake",
    "test_framework": "Catch2",
    "target_platforms": [
      "macOS",
      "Windows",
      "Linux"
    ],
    "primary_use_cases": [
      "education",
      "old sample preservation",
      "2D + simple 3D tutorials",
      "procedural beginner-friendly API"
    ],
    "non_goals": [
      "100% DarkGDK compatibility",
      "binary compatibility with historical DarkGDK libraries",
      "production-grade engine hardening",
      "recreating DirectX 9 rendering behavior",
      "shipping a scene editor or IDE"
    ]
  },
  "agent_guidance": {
    "execution_mode": "incremental",
    "planning_rule": "Do not start a story until all hard dependencies are complete and merged locally.",
    "implementation_rule": "Preserve public DarkGDK-style API shape while keeping internals namespaced under litegdk.",
    "tdd_rule": "Write or update failing Catch2 tests before implementation for all logic that can be tested headlessly.",
    "change_scope_rule": "Keep each story small enough to review in one PR. Avoid mixing unrelated command families.",
    "compatibility_rule": "Favor source-friendly behavior over historical quirks. Document approximations explicitly.",
    "docs_rule": "Update compatibility matrix and examples whenever a new public command family lands.",
    "quality_gates": [
      "cmake configure succeeds",
      "project builds cleanly",
      "tests pass",
      "new public API documented",
      "compatibility tier declared for every new command"
    ]
  },
  "architecture_summary": {
    "public_entrypoints": [
      "include/DarkGDK.h",
      "public db* procedural API functions",
      "user-defined void DarkGDK() entrypoint"
    ],
    "runtime_model": {
      "style": "single-process global runtime facade with explicit registries",
      "key_components": [
        "AppRuntime",
        "FrameState",
        "ConfigState",
        "ImageRegistry",
        "SpriteRegistry",
        "SoundRegistry",
        "MusicRegistry",
        "CameraRegistry",
        "ObjectRegistry",
        "InputSnapshot",
        "Diagnostics/Compatibility reporting"
      ]
    },
    "repo_layout": {
      "root_files": [
        "CMakeLists.txt",
        "README.md",
        "LICENSE",
        "CONTRIBUTING.md",
        "docs/",
