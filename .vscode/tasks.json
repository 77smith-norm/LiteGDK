{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "LiteGDK: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "debug"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build"
        },
        {
            "label": "LiteGDK: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "debug"
            ],
            "dependsOn": "LiteGDK: Configure",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "LiteGDK: Test",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--preset",
                "debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "LiteGDK: Build",
            "problemMatcher": [
                "$gcc"
            ],
            "group": "test"
        }
    ]
}
